{
  "name": "dlx-guard",
  "version": "0.6.0",
  "description": "Security wrapper for npx/pnpm dlx/bunx - warns about risky packages before running",
  "type": "module",
  "scripts": {
    "build": "bun build ./src/cli.ts --compile --outfile ./dist/dlx-guard",
    "dev": "bun run src/cli.ts",
    "test": "bun test",
    "lint": "bunx tsc --noEmit",
    "format": "bunx prettier --write .",
    "typecheck": "bunx tsc --noEmit",
    "prepublishOnly": "bun run build"
  },
  "bin": {
    "dlx-guard": "./dist/dlx-guard"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CONTRIBUTING.md"
  ],
  "keywords": [
    "npm",
    "npx",
    "pnpm",
    "bunx",
    "security",
    "supply-chain",
    "package-safety",
    "cli",
    "devtools"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/bun": "^1.3.11",
    "@types/node": "^20.11.0",
    "prettier": "^3.2.5",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "cli-spinners": "^2.9.2",
    "kleur": "^4.1.5"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yourusername/dlx-guard.git"
  },
  "bugs": {
    "url": "https://github.com/yourusername/dlx-guard/issues"
  },
  "homepage": "https://github.com/yourusername/dlx-guard#readme"
}
