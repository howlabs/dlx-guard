{
  "name": "dlx-guard",
  "version": "0.5.1",
  "description": "Security wrapper for npx/pnpm dlx/bunx - warns about risky packages before running",
  "type": "module",
  "scripts": {
    "build": "bun build ./src/cli.ts --compile --outfile ./dist/dlx-guard",
    "dev": "bun run src/cli.ts",
    "test": "bun test",
    "lint": "bunx tsc --noEmit",
    "format": "bunx prettier --write .",
    "typecheck": "bunx tsc --noEmit"
  },
  "bin": {
    "dlx-guard": "./dist/dlx-guard"
  },
  "keywords": [
    "npm",
    "npx",
    "security",
    "supply-chain",
    "package-safety"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/bun": "^1.3.11",
    "@types/node": "^20.11.0",
    "prettier": "^3.2.5",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "cli-spinners": "^2.9.2",
    "kleur": "^4.1.5"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
